    "jsonwebtoken": "^9.0.0",
    "pg": "^8.10.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^4.16.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
